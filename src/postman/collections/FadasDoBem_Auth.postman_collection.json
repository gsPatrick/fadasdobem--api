{
  "info": {
    "_postman_id": "fadbem-auth-collection-2026",
    "name": "FadasDoBem_Auth",
    "description": "Autenticação Fadas do Bem — use o ambiente `Fadas do Bem — Local` (`api_base_url`, `jwt_token`, `refresh_token`). Register/Login atualizam `jwt_token`; refresh opcional atualiza ambos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "    const json = pm.response.json();",
                  "    if (json && json.sucesso === true && json.dados) {",
                  "        if (json.dados.access_token) {",
                  "            pm.environment.set('jwt_token', json.dados.access_token);",
                  "        }",
                  "        if (json.dados.refresh_token) {",
                  "            pm.environment.set('refresh_token', json.dados.refresh_token);",
                  "        }",
                  "    }",
                  "} catch (e) {}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.demo@example.com\",\n  \"password\": \"senha_segura12\",\n  \"accepted_terms_version\": \"v1-2026-05\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/register",
            "description": "Cadastro inicial (Cliente + User). Tokens em `dados`."
          },
          "response": []
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "    const json = pm.response.json();",
                  "    if (json && json.sucesso === true && json.dados) {",
                  "        if (json.dados.access_token) {",
                  "            pm.environment.set('jwt_token', json.dados.access_token);",
                  "        }",
                  "        if (json.dados.refresh_token) {",
                  "            pm.environment.set('refresh_token', json.dados.refresh_token);",
                  "        }",
                  "    }",
                  "} catch (e) {}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.demo@example.com\",\n  \"password\": \"senha_segura12\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/login",
            "description": "Credenciais — script salva tokens no ambiente."
          },
          "response": []
        },
        {
          "name": "POST Refresh-token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "    const json = pm.response.json();",
                  "    if (json && json.sucesso === true && json.dados) {",
                  "        if (json.dados.access_token) pm.environment.set('jwt_token', json.dados.access_token);",
                  "        if (json.dados.refresh_token) pm.environment.set('refresh_token', json.dados.refresh_token);",
                  "    }",
                  "} catch (e) {}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/refresh-token",
            "description": "Rotação de refresh + novo access."
          },
          "response": []
        },
        {
          "name": "POST Forgot-password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.demo@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/forgot-password",
            "description": "Resposta sempre genérica; OTP no console do servidor (simulação)."
          },
          "response": []
        },
        {
          "name": "POST Reset-password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.demo@example.com\",\n  \"otp\": \"123456\",\n  \"new_password\": \"nova_senha_segura12\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/reset-password",
            "description": "Substitua otp pelo código do console após Forgot-password."
          },
          "response": []
        },
        {
          "name": "GET Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{api_base_url}}/auth/me",
            "description": "Bearer `{{jwt_token}}`."
          },
          "response": []
        },
        {
          "name": "PATCH Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"tratar_por\": \"Maria\",\n  \"data_nascimento\": \"1990-05-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/me",
            "description": "Atualização progressiva perfil cliente."
          },
          "response": []
        },
        {
          "name": "POST Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{api_base_url}}/auth/logout",
            "description": "Access no header + refresh no corpo para revogar a sessão."
          },
          "response": []
        }
      ]
    }
  ]
}
