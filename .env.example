# ─── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PUBLIC_URL=http://localhost:3000
SEQUELIZE_SYNC=false

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fadasdobem
DB_USER=postgres
DB_PASSWORD=COLE_SENHA_DO_POSTGRES
DB_LOGGING=false
# Opcional (PRD): sobrepõe host/user/pass acima quando preenchido
DATABASE_URL=
# PRD com SSL (ex.: RDS): defina true se necessário
DB_SSL=false

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_URL=

# ─── JWT (gere segredos longos, ex.: openssl rand -hex 32) ───────────────────
JWT_SECRET=GERE_SEGREDO_MINIMO_32_CARACTERES_EX_openssl_rand_hex_32
JWT_EXPIRES_IN=30m
JWT_ISSUER=fadasdobem-api
JWT_AUDIENCE=fadasdobem-clients

JWT_REFRESH_SECRET=GERE_OUTRO_SEGREDO_MINIMO_32_CARACTERES
JWT_REFRESH_EXPIRES_IN=12h

# ─── E-mail (Resend — `src/providers/mail/`) ───────────────────────────────────
RESEND_API_KEY=re_ColeSuaChaveResendAqui
EMAIL_FROM="Fadas do Bem <contato@seudominio.com.br>"

# ─── Evolution API ───────────────────────────────────────────────────────────
EVOLUTION_API_BASE_URL=https://COLE_URL_PUBLICA_DA_SUA_EVOLUTION_API
EVOLUTION_GLOBAL_API_KEY=COLE_SUA_EVOLUTION_GLOBAL_API_KEY
EVOLUTION_WEBHOOK_GLOBAL_URL=

# ─── Chatwoot ────────────────────────────────────────────────────────────────
CHATWOOT_BASE_URL=https://COLE_URL_PUBLICA_DO_SEU_CHATWOOT
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_ACCESS_TOKEN=COLE_SEU_TOKEN_USER_OU_PLATFORM_CHATWOOT
CHATWOOT_IA_HISTORY_N=30

# ─── Provedor de IA: anthropic | openai ───────────────────────────────────────
ACTIVE_AI_PROVIDER=anthropic

# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-COLE_SUA_CHAVE_ANTHROPIC_AQUI
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_MAX_TOOL_ROUNDS=10

# ─── OpenAI (Assistants v2) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-COLE_SUA_CHAVE_OPENAI_OU_DEIXE_VAZIO
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_ASSISTANT_DISPLAY_NAME=
OPENAI_ASSISTANT_REGISTRY_SLUG=
OPENAI_ASSISTANT_ID=
OPENAI_RUN_POLL_MS=750
OPENAI_RUN_MAX_POLL_ATTEMPTS=60

# ─── Opcional ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=
